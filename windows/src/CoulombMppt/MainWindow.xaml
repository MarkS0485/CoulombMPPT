<Window x:Class="CoulombMppt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CoulombMPPT"
        Background="{StaticResource Body0}"
        FontFamily="Segoe UI" FontSize="12"
        Width="1180" Height="780"
        MinWidth="960" MinHeight="640">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Thin app bar with brand gradient + live status -->
        <Border Grid.Row="0" Background="{StaticResource BrandTopBarBrush}" Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="CoulombMPPT"
                           FontSize="14" FontWeight="SemiBold" Foreground="White"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" x:Name="StatusInline"
                           Foreground="#CCFFFFFF" Margin="14,0,0,0"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" x:Name="HeroInline"
                           Foreground="White" FontWeight="SemiBold" FontSize="14"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Body: left rail + content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource Body1}"
                    BorderBrush="{StaticResource LineGrey}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="RailItems" Margin="0,8">
                        <TextBlock Text="OPERATE" Style="{StaticResource SectionHeader}" Margin="12,4,0,2"/>
                        <ToggleButton x:Name="NavDashboard" Style="{StaticResource NavRailButton}" Click="OnNav" Tag="dashboard">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Dashboard"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="NavInverter" Style="{StaticResource NavRailButton}" Click="OnNav" Tag="inverter">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Inverter"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="NavBattery" Style="{StaticResource NavRailButton}" Click="OnNav" Tag="battery">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE83E;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Battery model"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="NavLive" Style="{StaticResource NavRailButton}" Click="OnNav" Tag="live">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Live data"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="NavScan" Style="{StaticResource NavRailButton}" Click="OnNav" Tag="scan">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE702;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Scan / pair"/>
                            </StackPanel>
                        </ToggleButton>

                        <TextBlock Text="CONFIGURE" Style="{StaticResource SectionHeader}" Margin="12,12,0,2"/>
                        <ToggleButton x:Name="NavSettings" Style="{StaticResource NavRailButton}" Click="OnNav" Tag="settings">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Controller settings"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="NavApp" Style="{StaticResource NavRailButton}" Click="OnNav" Tag="app">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE115;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="App settings"/>
                            </StackPanel>
                        </ToggleButton>

                        <TextBlock Text="MONITOR" Style="{StaticResource SectionHeader}" Margin="12,12,0,2"/>
                        <ToggleButton x:Name="NavHistory" Style="{StaticResource NavRailButton}" Click="OnNav" Tag="history">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="History"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="NavAlerts" Style="{StaticResource NavRailButton}" Click="OnNav" Tag="alerts">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Alerts"/>
                            </StackPanel>
                        </ToggleButton>

                        <TextBlock Text="DIAGNOSE" Style="{StaticResource SectionHeader}" Margin="12,12,0,2"/>
                        <ToggleButton x:Name="NavDiag" Style="{StaticResource NavRailButton}" Click="OnNav" Tag="diag">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Diagnostics"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="NavLog" Style="{StaticResource NavRailButton}" Click="OnNav" Tag="log">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Log viewer"/>
                            </StackPanel>
                        </ToggleButton>

                        <TextBlock Text="REMOTE" Style="{StaticResource SectionHeader}" Margin="12,12,0,2"/>
                        <ToggleButton x:Name="NavApi" Style="{StaticResource NavRailButton}" Click="OnNav" Tag="api">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Remote API"/>
                            </StackPanel>
                        </ToggleButton>

                        <TextBlock Text="ABOUT" Style="{StaticResource SectionHeader}" Margin="12,12,0,2"/>
                        <ToggleButton x:Name="NavAbout" Style="{StaticResource NavRailButton}" Click="OnNav" Tag="about">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="About"/>
                            </StackPanel>
                        </ToggleButton>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Content area: shows the currently-selected destination, or a
                 pushed sub-page over the top. -->
            <Grid Grid.Column="1">
                <ContentControl x:Name="ContentHost"/>
                <ContentControl x:Name="OverlayHost" Visibility="Collapsed"
                                Background="{StaticResource Body0}"/>
            </Grid>
        </Grid>

        <!-- Bottom status bar -->
        <Border Grid.Row="2" Background="{StaticResource Body1}"
                BorderBrush="{StaticResource LineGrey}" BorderThickness="0,1,0,0"
                Padding="12,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusBarText" Style="{StaticResource Caption}"/>
                <TextBlock Grid.Column="1" x:Name="LastRxText" Style="{StaticResource Caption}" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="2" x:Name="CurrentMacText" Style="{StaticResource Mono}" FontSize="11"
                           Foreground="{StaticResource InkLo}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
