<UserControl x:Class="CoulombMppt.Ui.Controls.OxyChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf">
    <Grid>
        <oxy:PlotView x:Name="Plot" Background="Transparent"/>
        <TextBlock x:Name="LabelText" VerticalAlignment="Top" HorizontalAlignment="Left"
                   Margin="8,4" FontSize="11" Opacity="0.6"/>
    </Grid>
</UserControl>
