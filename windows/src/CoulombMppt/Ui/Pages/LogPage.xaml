<UserControl x:Class="CoulombMppt.Ui.Pages.LogPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:CoulombMppt.Ui.Controls">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <c:PageHeader Grid.Row="0" Title="Log" Subtitle="Live tail of this session's diagnostic log">
            <c:PageHeader.ActionContent>
                <StackPanel Orientation="Horizontal">
                    <ToggleButton Content="Follow" IsChecked="True"
                                  Style="{StaticResource OutlinedToggle}" Margin="0,0,6,0"
                                  Checked="OnFollowToggled" Unchecked="OnFollowToggled"/>
                    <Button Content="Reload" Style="{StaticResource OutlinedButton}" Margin="0,0,6,0" Click="OnReload"/>
                    <Button Content="Open folder" Style="{StaticResource OutlinedButton}" Click="OnOpenFolder"/>
                </StackPanel>
            </c:PageHeader.ActionContent>
        </c:PageHeader>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <DockPanel>
                <TextBlock x:Name="LogPathLine" DockPanel.Dock="Top" Style="{StaticResource Mono}"
                           FontSize="11" Foreground="{StaticResource InkLo}" Margin="0,0,0,6"/>
                <TextBox x:Name="LogBox" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                         FontFamily="Cascadia Mono, Consolas" FontSize="12"
                         Background="{StaticResource Body2}" BorderThickness="0"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
