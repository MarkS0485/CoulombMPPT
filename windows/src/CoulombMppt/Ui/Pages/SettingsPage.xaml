<UserControl x:Class="CoulombMppt.Ui.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:CoulombMppt.Ui.Controls"
             xmlns:vm="clr-namespace:CoulombMppt.Ui.ViewModels">
    <UserControl.DataContext>
        <vm:SettingsViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="FieldRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,6"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <c:PageHeader Title="Controller settings"
                          Subtitle="Read and write the controller's configuration registers">
                <c:PageHeader.ActionContent>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Working…" Foreground="{StaticResource SolarTeal}" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,10,0"
                                   Visibility="{Binding Busy, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Read" Style="{StaticResource OutlinedButton}" Margin="0,0,6,0"
                                Command="{Binding ReadCommand}"/>
                        <Button Content="Apply changes" Style="{StaticResource PrimaryButton}"
                                Command="{Binding ApplyCommand}"/>
                    </StackPanel>
                </c:PageHeader.ActionContent>
            </c:PageHeader>

            <TextBlock Text="No settings loaded yet — press Read (the controller must be connected)."
                       Style="{StaticResource Caption}" Margin="0,0,0,8"
                       Visibility="{Binding HasSettings, Converter={StaticResource BoolToVisInv}}"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: charging profile -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="CHARGING PROFILE" Style="{StaticResource SectionHeader}"/>

                        <Grid Style="{StaticResource FieldRow}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="160"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Battery type" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" Padding="6,3"
                                      SelectedIndex="{Binding BatteryTypeIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="Unknown"/>
                                <ComboBoxItem Content="Sealed lead-acid"/>
                                <ComboBoxItem Content="Gel lead-acid"/>
                                <ComboBoxItem Content="Flooded lead-acid"/>
                                <ComboBoxItem Content="Lithium (LiFePO4)"/>
                            </ComboBox>
                        </Grid>

                        <Grid Style="{StaticResource FieldRow}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="160"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Charge / boost voltage (V)" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Padding="6,3" FontFamily="Cascadia Mono, Consolas"
                                     Text="{Binding ChargeVoltageInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <Grid Style="{StaticResource FieldRow}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="160"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Cutoff / low-disconnect (V)" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Padding="6,3" FontFamily="Cascadia Mono, Consolas"
                                     Text="{Binding CutoffVoltageInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <Grid Style="{StaticResource FieldRow}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="160"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Recovery / reconnect (V)" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Padding="6,3" FontFamily="Cascadia Mono, Consolas"
                                     Text="{Binding RecoveryVoltageInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- RIGHT: load / output -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="LOAD / OUTPUT" Style="{StaticResource SectionHeader}"/>

                        <Grid Style="{StaticResource FieldRow}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="160"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Output mode" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" Padding="6,3"
                                      SelectedIndex="{Binding OutputModeIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="Manual"/>
                                <ComboBoxItem Content="Auto / dusk-to-dawn"/>
                                <ComboBoxItem Content="Timer"/>
                            </ComboBox>
                        </Grid>

                        <Grid Style="{StaticResource FieldRow}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="160"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Manual load output" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                            <CheckBox Grid.Column="1" Content="On" VerticalAlignment="Center"
                                      IsChecked="{Binding ManualLoadOn, Mode=TwoWay}"/>
                        </Grid>

                        <Grid Style="{StaticResource FieldRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="75"/>
                                <ColumnDefinition Width="75"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Timer (h / m)" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Padding="6,3" Margin="0,0,4,0" FontFamily="Cascadia Mono, Consolas"
                                     Text="{Binding TimerHoursInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Grid.Column="2" Padding="6,3" Margin="4,0,0,0" FontFamily="Cascadia Mono, Consolas"
                                     Text="{Binding TimerMinutesInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <Grid Style="{StaticResource FieldRow}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="160"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Voltage monitor mode" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Padding="6,3" FontFamily="Cascadia Mono, Consolas"
                                     Text="{Binding VoltageMonitorModeInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <Button Content="Toggle load now" Style="{StaticResource OutlinedButton}"
                                HorizontalAlignment="Left" Margin="0,8,0,0"
                                Command="{Binding ToggleLoadCommand}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="{Binding Status}" Style="{StaticResource Caption}" Margin="2,12,0,0"
                       Visibility="{Binding Status, Converter={StaticResource StringNotEmptyToVis}}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
