<UserControl x:Class="CoulombMppt.Ui.Pages.AlertsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:CoulombMppt.Ui.Controls"
             xmlns:vm="clr-namespace:CoulombMppt.Ui.ViewModels">
    <UserControl.DataContext>
        <vm:AlertsViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <c:PageHeader Grid.Row="0" Title="Alerts"
                      Subtitle="Threshold crossings raised by the alert engine">
            <c:PageHeader.ActionContent>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Dismiss all" Style="{StaticResource OutlinedButton}" Margin="0,0,6,0"
                            Command="{Binding DismissAllCommand}"/>
                    <Button Content="Clear log" Style="{StaticResource DangerButton}"
                            Command="{Binding ClearCommand}"/>
                </StackPanel>
            </c:PageHeader.ActionContent>
        </c:PageHeader>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="{Binding Summary}" Style="{StaticResource Caption}" Margin="0,0,0,8"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Alerts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource Body2}" CornerRadius="6"
                                        Padding="12,8" Margin="0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" CornerRadius="4" Padding="6,2" Margin="0,0,12,0"
                                                VerticalAlignment="Top"
                                                Background="{Binding Severity, Converter={StaticResource SeverityToBrush}}">
                                            <TextBlock Text="{Binding Severity}" Foreground="White"
                                                       FontWeight="SemiBold" FontSize="11"/>
                                        </Border>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Message}" Style="{StaticResource Body}" TextWrapping="Wrap"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding Kind}" Style="{StaticResource Caption}" Margin="0,0,10,0"/>
                                                <TextBlock Style="{StaticResource Caption}">
                                                    <Run Text="observed "/>
                                                    <Run Text="{Binding Observed, StringFormat={}{0:0.##}}"/>
                                                    <Run Text="  ·  threshold "/>
                                                    <Run Text="{Binding Threshold, StringFormat={}{0:0.##}}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Style="{StaticResource Caption}" Foreground="{StaticResource InkLo}"
                                                       Text="{Binding TimestampMs, Converter={StaticResource UnixMsToDateTime}}"/>
                                        </StackPanel>

                                        <Button Grid.Column="2" Content="Dismiss" Style="{StaticResource OutlinedButton}"
                                                VerticalAlignment="Top"
                                                Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}"
                                                Command="{Binding DataContext.DismissCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
