<UserControl x:Class="CoulombMppt.Ui.Pages.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:CoulombMppt.Ui.Controls">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <c:PageHeader Grid.Row="0" Title="About" Subtitle="CoulombMPPT Windows client"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="CoulombMPPT" Style="{StaticResource H1}"/>
                        <TextBlock x:Name="VersionLine" Style="{StaticResource Caption}"/>
                        <TextBlock Style="{StaticResource Body}" Margin="0,6,0,0" TextWrapping="Wrap"
                                   Text="Windows companion to the Android MPPT app. Same BLE protocol and data model, with richer logging, history charts and a remote-control API."/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Log file" Style="{StaticResource H2}"/>
                        <TextBlock x:Name="LogPathLine" Style="{StaticResource Mono}" FontSize="12" TextWrapping="Wrap"/>
                        <Button Style="{StaticResource OutlinedButton}" Content="Open log folder"
                                Margin="0,8,0,0" HorizontalAlignment="Left" Click="OnOpenLog"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Data folder" Style="{StaticResource H2}"/>
                        <TextBlock x:Name="DataPathLine" Style="{StaticResource Mono}" FontSize="12" TextWrapping="Wrap"/>
                        <Button Style="{StaticResource OutlinedButton}" Content="Open data folder"
                                Margin="0,8,0,0" HorizontalAlignment="Left" Click="OnOpenData"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Source &amp; protocol" Style="{StaticResource H2}"/>
                        <TextBlock Style="{StaticResource Body}" TextWrapping="Wrap"
                                   Text="Protocol details are documented in docs/BLE_PROTOCOL.md at the project root."/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
