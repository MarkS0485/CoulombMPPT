<UserControl x:Class="CoulombMppt.Ui.Pages.ScanPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:CoulombMppt.Ui.Controls"
             xmlns:vm="clr-namespace:CoulombMppt.Ui.ViewModels">
    <UserControl.DataContext>
        <vm:ScanViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <c:PageHeader Grid.Row="0" Title="Scan / pair"
                      Subtitle="Find nearby controllers over Bluetooth LE and pair them">
            <c:PageHeader.ActionContent>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Scanning…" Foreground="{StaticResource SolarTeal}" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,10,0"
                               Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="Start / stop scan" Style="{StaticResource PrimaryButton}"
                            Command="{Binding ToggleScanCommand}"/>
                </StackPanel>
            </c:PageHeader.ActionContent>
        </c:PageHeader>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Discovered -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="NEARBY DEVICES" Style="{StaticResource SectionHeader}"/>
                    <TextBlock DockPanel.Dock="Top"
                               Text="No devices yet — press Start scan."
                               Style="{StaticResource Caption}"
                               Visibility="{Binding Devices.Count, Converter={StaticResource CountZeroToVis}}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Devices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource Body2}" CornerRadius="6"
                                            Padding="12,8" Margin="0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Display}" Style="{StaticResource H2}"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Rssi, StringFormat={}{0} dBm}"
                                                               Style="{StaticResource Caption}" Margin="0,0,10,0"/>
                                                    <TextBlock Text="known MPPT"
                                                               Style="{StaticResource Caption}"
                                                               Foreground="{StaticResource SolarTeal}"
                                                               Visibility="{Binding IsKnownMppt, Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Pair"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Command="{Binding DataContext.PairCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Paired -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="PAIRED CONTROLLERS" Style="{StaticResource SectionHeader}"/>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Nothing paired yet."
                               Style="{StaticResource Caption}"
                               Visibility="{Binding Paired.Count, Converter={StaticResource CountZeroToVis}}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Paired}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource Body2}" CornerRadius="6"
                                            Padding="12,8" Margin="0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Label}" Style="{StaticResource H2}"/>
                                                <TextBlock Text="{Binding Mac}" Style="{StaticResource Mono}"
                                                           FontSize="11" Foreground="{StaticResource InkLo}"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Connect"
                                                    Style="{StaticResource OutlinedButton}" Margin="0,0,6,0"
                                                    Command="{Binding DataContext.ConnectCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Grid.Column="2" Content="Forget"
                                                    Style="{StaticResource DangerButton}"
                                                    Command="{Binding DataContext.ForgetCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
