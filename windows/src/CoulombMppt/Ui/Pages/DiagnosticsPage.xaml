<UserControl x:Class="CoulombMppt.Ui.Pages.DiagnosticsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:CoulombMppt.Ui.Controls">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <c:PageHeader Grid.Row="0" Title="Diagnostics"
                      Subtitle="Raw BLE frame monitor and manual register access">
            <c:PageHeader.ActionContent>
                <StackPanel Orientation="Horizontal">
                    <ToggleButton Content="Pause" Style="{StaticResource OutlinedToggle}"
                                  Margin="0,0,6,0" Checked="OnPauseToggled" Unchecked="OnPauseToggled"/>
                    <Button Content="Clear" Style="{StaticResource OutlinedButton}" Click="OnClear"/>
                </StackPanel>
            </c:PageHeader.ActionContent>
        </c:PageHeader>

        <!-- Manual register read/write -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="MANUAL REGISTER WRITE" Style="{StaticResource SectionHeader}"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Register" Style="{StaticResource Body}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="RegBox" Width="90" Padding="6,3" FontFamily="Cascadia Mono, Consolas" Text="0x"/>
                    <TextBlock Text="Value" Style="{StaticResource Body}" VerticalAlignment="Center" Margin="14,0,6,0"/>
                    <TextBox x:Name="ValBox" Width="90" Padding="6,3" FontFamily="Cascadia Mono, Consolas" Text="0"/>
                    <Button Content="Write" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="OnWriteRegister"/>
                    <TextBlock x:Name="WriteStatus" Style="{StaticResource Caption}"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>
                <TextBlock Style="{StaticResource Caption}" Margin="0,6,0,0" TextWrapping="Wrap"
                           Text="Address and value accept decimal or 0x-prefixed hex. Writes go straight to the controller — use with care."/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="RAW FRAMES (newest at bottom)" Style="{StaticResource SectionHeader}"/>
                <ScrollViewer x:Name="FrameScroll" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="FrameList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Time}" Style="{StaticResource Mono}"
                                               FontSize="11" Foreground="{StaticResource InkLo}" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Dir}" Style="{StaticResource Mono}"
                                               FontSize="11" FontWeight="SemiBold" Width="28"
                                               Foreground="{Binding Tx, Converter={StaticResource TxToBrush}}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Hex}" Style="{StaticResource Mono}"
                                               FontSize="11" TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
