# ----------------------------------------------------------------------------
# Windows app — .NET / Visual Studio / Rider / dotnet build
# Self-contained so this folder can stand alone as its own project/repo.
# ----------------------------------------------------------------------------

# Build output
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/

# Visual Studio user-local state
*.user
*.suo
*.userprefs
*.userosscache
*.sln.docstates
.vs/

# Rider / JetBrains
*.DotSettings.user
.idea/

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
project.lock.json
project.fragment.lock.json
*.nuget.props
*.nuget.targets

# MSBuild / debug
*.pdb
*.tlog
*.cache
*.vspscc
*.vssscc

# Publish output
publish/
PublishProfiles/
*.[Pp]ublish.xml
*.azurePubxml

# Installer build output (compiled setup.exe — large, regenerated by tools/build-installer.ps1)
installer/Output/

# Code coverage / test
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
coverage*.xml
coverage*.json

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper

# Runtime / local app state we don't want committed
*.pfx
*.p12
paired-clients.json
server.pfx
